@database("ft_sqlite");

@meta({
    name: "customers";
    description: "CLI full-test table: computed field + trigger + seeder + alter";
});

@columns({
    id: {
        type: "int";
        options: ["primary", "autoincrement"];
    };
    first_name: {
        type: "varchar";
        length: "120";
        options: ["not null"];
    };
    last_name: {
        type: "varchar";
        length: "120";
        options: ["not null"];
    };
    email: {
        type: "varchar";
        length: "190";
    };
    full_name: {
        type: "string";
        value: @compute(()=>{
            const full = @column(first_name) + " " + @column(last_name);
            return full;
        });
    };
});
